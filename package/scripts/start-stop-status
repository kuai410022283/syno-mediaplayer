#!/bin/sh

# MediaPlayer Synology Package - start-stop-status script (DSM 7)

PACKAGE_NAME="MediaPlayer"
TARGET_DIR="/var/packages/${PACKAGE_NAME}/target"
DAEMON="${TARGET_DIR}/bin/mediaplayer"

# 优先使用 File Station 中完全可见的 web_packages / web 共享目录
get_data_dir() {
    # 1. 优先使用 DSM 官方 usr-share 资源赋予的共享路径 (web_packages/MediaPlayer)
    if [ -n "${SYNOPKG_SHARE_PATH}" ] && [ -d "${SYNOPKG_SHARE_PATH}" ]; then
        echo "${SYNOPKG_SHARE_PATH}"
        return 0
    fi

    DATA_DIR_FILE="${TARGET_DIR}/var/data_path"
    if [ -f "${DATA_DIR_FILE}" ]; then
        SAVED_DIR=$(cat "${DATA_DIR_FILE}" | tr -d '\r\n')
        if [ -n "${SAVED_DIR}" ] && [ -d "${SAVED_DIR}" ]; then
            echo "${SAVED_DIR}"
            return 0
        fi
    fi

    REAL_TARGET=$(readlink -f "${TARGET_DIR}" 2>/dev/null || realpath "${TARGET_DIR}" 2>/dev/null || echo "${SYNOPKG_PKGDEST:-}")
    VOL_DIR=$(echo "${REAL_TARGET}" | awk -F'/' '{if ($2 ~ /^volume/) print "/"$2}')
    [ -z "${VOL_DIR}" ] && VOL_DIR="/volume1"

    for candidate in "${VOL_DIR}/web_packages/${PACKAGE_NAME}" "/var/services/web_packages/${PACKAGE_NAME}" "${VOL_DIR}/web/${PACKAGE_NAME}"; do
        if [ -d "${candidate}" ] || mkdir -p "${candidate}" 2>/dev/null; then
            chmod 777 "${candidate}" 2>/dev/null || true
            if touch "${candidate}/.test_write" 2>/dev/null; then
                rm -f "${candidate}/.test_write" 2>/dev/null || true
                echo "${candidate}"
                return 0
            fi
        fi
    done

    SYNO_SHARE_GET=$(synoshare --get "${PACKAGE_NAME}" 2>/dev/null | grep -i "Path" | awk -F'[' '{print $2}' | tr -d ']')
    if [ -n "${SYNO_SHARE_GET}" ] && [ -d "${SYNO_SHARE_GET}" ]; then
        echo "${SYNO_SHARE_GET}"
        return 0
    fi

    echo "${SYNOPKG_PKGVAR:-/var/packages/${PACKAGE_NAME}/var}"
}

DATA_DIR=$(get_data_dir)

LOG_FILE="${DATA_DIR}/mediaplayer.log"
PID_FILE="${DATA_DIR}/mediaplayer.pid"
CONFIG_FILE="${DATA_DIR}/config.yaml"
CONFIG_TEMPLATE="${TARGET_DIR}/etc/config.yaml.template"

log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >>"${LOG_FILE}"
}

fail() {
    local msg="$1"
    log_msg "FAIL: ${msg}"
    if [ -n "${SYNOPKG_TEMP_LOGFILE:-}" ]; then
        echo "${msg}" >"${SYNOPKG_TEMP_LOGFILE}"
    fi
    return 1
}

status() {
    if [ -f "${PID_FILE}" ]; then
        local pid
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')
        if [ -n "${pid}" ] && kill -0 "${pid}" 2>/dev/null; then
            return 0
        fi
    fi
    return 1
}

start_process() {
    if status; then
        log_msg "Process already running (PID $(head -n 1 "${PID_FILE}"))"
        return 0
    fi

    # 清理可能残留的无 PID 文件孤儿进程，避免端口绑定冲突
    pkill -f "bin/mediaplayer" 2>/dev/null || killall mediaplayer 2>/dev/null || true

    log_msg "========== STARTING =========="
    mkdir -p "${DATA_DIR}"
    mkdir -p "${TARGET_DIR}/var"

    if [ ! -f "${DAEMON}" ]; then
        fail "Binary not found: ${DAEMON}"
        return 1
    fi

    chmod +x "${DAEMON}"

    # 确保用户数据目录存在
    mkdir -p "${DATA_DIR}/data/cache"
    mkdir -p "${DATA_DIR}/library"

    # 处理 web 静态资源目录（解决 TARGET_DIR 只读问题以及 download 目录需写权限的问题）
    if [ -d "${TARGET_DIR}/web" ]; then
        mkdir -p "${DATA_DIR}/web"
        # 将 target 侧的静态文件软链接到运行目录
        find "${TARGET_DIR}/web" -mindepth 1 -maxdepth 1 | while read -r item; do
            basename=$(basename "${item}")
            if [ "${basename}" != "download" ]; then
                ln -sf "${item}" "${DATA_DIR}/web/${basename}"
            fi
        done
    fi
    # 强制独立创建真实可写的 download 目录
    mkdir -p "${DATA_DIR}/web/download"

    # 确保配置文件存在
    if [ ! -f "${CONFIG_FILE}" ]; then
        if [ -f "${CONFIG_TEMPLATE}" ]; then
            cp "${CONFIG_TEMPLATE}" "${CONFIG_FILE}"
            log_msg "Config copied from template"
        else
            fail "Config not found: ${CONFIG_FILE}"
            return 1
        fi
    fi

    # 检查配置中是否还有相对路径，如果有则修复为绝对路径
    if grep -q '\./data/' "${CONFIG_FILE}" 2>/dev/null; then
        log_msg "Fixing relative paths in config..."
        sed -i "s|\./data/|${DATA_DIR}/data/|g" "${CONFIG_FILE}"
    fi

    log_msg "Exec: ${DAEMON}"
    log_msg "Data dir: ${DATA_DIR}"
    log_msg "Config: ${CONFIG_FILE}"

    # 直接在数据目录下运行二进制
    # 二进制从 cwd 读取 config.yaml
    cd "${DATA_DIR}"

    export LD_LIBRARY_PATH="${TARGET_DIR}/lib:${LD_LIBRARY_PATH:-}"

    nohup "${DAEMON}" >>"${LOG_FILE}" 2>&1 &
    local newpid=$!
    echo "${newpid}" >"${PID_FILE}"

    sleep 2
    if kill -0 "${newpid}" 2>/dev/null; then
        log_msg "Started successfully (PID: ${newpid})"
        return 0
    else
        fail "Failed to start. Check log: ${LOG_FILE}"
        return 1
    fi
}

stop_process() {
    if ! status; then
        log_msg "Process not running via PID file. Attempting zombie cleanup..."
        pkill -f "bin/mediaplayer" 2>/dev/null || killall mediaplayer 2>/dev/null || true
        rm -f "${PID_FILE}"
        return 0
    fi

    log_msg "========== STOPPING =========="
    local pid
    pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')

    if [ -n "${pid}" ]; then
        log_msg "Sending SIGTERM to PID ${pid}"
        kill "${pid}" 2>/dev/null

        local timeout=10
        while [ ${timeout} -gt 0 ] && kill -0 "${pid}" 2>/dev/null; do
            sleep 1
            timeout=$((timeout - 1))
        done

        if kill -0 "${pid}" 2>/dev/null; then
            log_msg "Force killing PID ${pid}"
            kill -9 "${pid}" 2>/dev/null
        fi
    fi

    rm -f "${PID_FILE}"
    log_msg "Stopped"
    return 0
}

case "$1" in
    start)
        start_process
        exit $?
        ;;
    stop)
        stop_process
        exit 0
        ;;
    status)
        if status; then
            echo "MediaPlayer is running (PID: $(head -n 1 "${PID_FILE}"))"
            exit 0
        else
            echo "MediaPlayer is not running"
            exit 1
        fi
        ;;
    prestart|prestop)
        exit 0
        ;;
    *)
        echo "Usage: $0 {start|stop|status|prestart|prestop}"
        exit 1
        ;;
esac
