#!/bin/sh

# Pre-installation script for MediaPlayer

# Check if port 9527 is available
if command -v ss > /dev/null 2>&1; then
    if ss -tlnp | grep -q ':9527 '; then
        echo "Error: Port 9527 is already in use."
        echo "Please stop the service using port 9527 first."
        exit 1
    fi
elif command -v netstat > /dev/null 2>&1; then
    if netstat -tlnp | grep -q ':9527 '; then
        echo "Error: Port 9527 is already in use."
        exit 1
    fi
fi

exit 0
