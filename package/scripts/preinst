#!/bin/sh

# Pre-installation script for MediaPlayer

# Check if default port 9527 is in use and output warning if detected
IS_USED=0
if command -v ss > /dev/null 2>&1; then
    if ss -tlnp 2>/dev/null | grep -q ':9527[[:space:]]'; then
        IS_USED=1
    fi
elif command -v netstat > /dev/null 2>&1; then
    if netstat -tlnp 2>/dev/null | grep -q ':9527[[:space:]]'; then
        IS_USED=1
    fi
fi

if [ ${IS_USED} -eq 1 ]; then
    echo "Warning: Default port 9527 appears to be in use. You can specify a custom port in the installation wizard."
fi

# Prepare web_packages directory as root for DSM 7
PACKAGE_NAME="MediaPlayer"
PACKAGE_USER="sc-MediaPlayer"

for puser in "${PACKAGE_USER}" "${PACKAGE_NAME}"; do
    for vol in /volume* /var/services; do
        if [ -d "${vol}/web_packages" ]; then
            /usr/syno/bin/synoacltool -add "${vol}/web_packages" "user:${puser}:allow:rwxpdDaARWcCo:fd--" 2>/dev/null || true
            target="${vol}/web_packages/${PACKAGE_NAME}"
            mkdir -p "${target}" 2>/dev/null || true
            /usr/syno/bin/synoacltool -add "${target}" "user:${puser}:allow:rwxpdDaARWcCo:fd--" 2>/dev/null || true
            chmod 777 "${target}" 2>/dev/null || true
        fi
    done
done

exit 0
