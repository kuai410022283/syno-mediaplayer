#!/bin/sh

# Post-upgrade script for MediaPlayer

PACKAGE_NAME="MediaPlayer"
TARGET_DIR="/var/packages/${PACKAGE_NAME}/target"
DATA_DIR_FILE="${TARGET_DIR}/var/data_path"
PACKAGE_USER="sc-MediaPlayer"

echo "MediaPlayer 升级处理中..."

# 1. 设置执行权限
chmod +x "${TARGET_DIR}/bin/mediaplayer" 2>/dev/null || true

# 2. 读取数据路径
if [ -f "${DATA_DIR_FILE}" ]; then
    DATA_DIR=$(cat "${DATA_DIR_FILE}" | tr -d '\n')
else
    DATA_DIR="/volume1/MediaPlayerData"
fi

echo "数据目录: ${DATA_DIR}"

# 3. 确保数据目录存在
mkdir -p "${DATA_DIR}/data/cache"
mkdir -p "${DATA_DIR}/config"

# 4. 如果向导提供了新数据路径，更新记录
if [ -n "${data_path}" ] && [ "${data_path}" != "" ]; then
    # 迁移数据
    if [ -d "${DATA_DIR}" ] && [ "${DATA_DIR}" != "${data_path}" ]; then
        echo "迁移数据: ${DATA_DIR} -> ${data_path}"
        mkdir -p "${data_path}"
        cp -a "${DATA_DIR}/"* "${data_path}/" 2>/dev/null || true
    fi
    echo "${data_path}" > "${DATA_DIR_FILE}"
    DATA_DIR="${data_path}"
    echo "数据路径已更新: ${DATA_DIR}"
fi

# 5. 更新配置文件中的路径（如果使用默认配置）
CONFIG_FILE="${DATA_DIR}/config/config.yaml"
if [ -f "${CONFIG_FILE}" ]; then
    # 确保数据库路径指向正确的数据目录
    sed -i "s|path: \"\./data/|path: \"${DATA_DIR}/data/|g" "${CONFIG_FILE}"
    sed -i "s|cache_dir: \"\./data/|cache_dir: \"${DATA_DIR}/data/|g" "${CONFIG_FILE}"
    echo "配置文件路径已更新"
fi

# 6. 确保包用户拥有数据目录的写权限
chown -R "${PACKAGE_USER}:users" "${DATA_DIR}"
chmod -R 775 "${DATA_DIR}"

echo "MediaPlayer 升级完成！"
exit 0
