#!/bin/sh

# Post-installation script for MediaPlayer (DSM 7)

PACKAGE_NAME="MediaPlayer"
TARGET_DIR="/var/packages/${PACKAGE_NAME}/target"

# DSM 7 标准环境变量
# SYNOPKG_PKGVAR = /var/packages/<package>/var (持久化数据，升级不丢失)
# SYNOPKG_PKGDEST = /var/packages/<package>/target (安装目录)
DATA_DIR="${SYNOPKG_PKGVAR:-/var/packages/${PACKAGE_NAME}/var}"
PACKAGE_USER="sc-MediaPlayer"

echo "开始安装 MediaPlayer..."
echo "安装目录: ${TARGET_DIR}"
echo "数据目录: ${DATA_DIR}"

# 1. 设置执行权限
chmod +x "${TARGET_DIR}/bin/mediaplayer" 2>/dev/null || true
chmod +x "${TARGET_DIR}/scripts/"* 2>/dev/null || true

# 2. 创建数据目录结构（DSM 7 标准路径）
mkdir -p "${DATA_DIR}/data/cache"

# 3. 生成或保留配置文件（绝对路径）
TARGET_CONFIG="${DATA_DIR}/config.yaml"

if [ -f "${TARGET_CONFIG}" ]; then
    echo "发现已存在的配置文件，保留原有配置（升级模式）"
    # 尝试从现有配置文件中提取端口，以便更新桌面快捷方式
    EXISTING_PORT=$(grep '^[[:space:]]*port:' "${TARGET_CONFIG}" | awk '{print $2}' | tr -d '\r')
    if [ -n "${EXISTING_PORT}" ]; then
        PORT="${EXISTING_PORT}"
        echo "提取到已有端口: ${PORT}"
    else
        PORT="9527"
    fi
else
    echo "全新安装，生成配置文件..."
    TEMPLATE_FILE="${TARGET_DIR}/etc/config.yaml.template"
    PORT="${server_port:-9527}"
    ADMIN_PWD="${admin_password:-admin123}"

    SECRET_KEY=$(head -c 32 /dev/urandom | tr -dc 'a-zA-Z0-9' | head -c 32 2>/dev/null)
    if [ -z "${SECRET_KEY}" ]; then
        SECRET_KEY="mediaplayer-fallback-$(date +%s)"
    fi

    # 使用官方推荐的环境变量直出模式，摒弃脆弱的 sed 正则替换
    cat <<EOF >"${TARGET_CONFIG}"
server:
  host: "0.0.0.0"
  port: ${PORT}

database:
  path: "${DATA_DIR}/data/mediaplayer.db"

stream:
  cache_dir: "${DATA_DIR}/data/cache"
  max_concurrent: 1000
  buffer_size: 8192

auth:
  secret: "${SECRET_KEY}"
  expire_hours: 720
  admin_password: "${ADMIN_PWD}"

cors:
  allowed_origins:
    - "*"

rate_limit:
  api: 1000
  logo: 1000
  stream: 2000
EOF
fi

    # 验证配置生成
    if grep -q "${DATA_DIR}" "${TARGET_CONFIG}" 2>/dev/null; then
        echo "配置生成成功（绝对路径）"
    else
        echo "警告：sed 替换可能未生效，手动修复路径"
        sed -i "s|path: \"./data/|path: \"${DATA_DIR}/data/|g" "${TARGET_CONFIG}"
        sed -i "s|cache_dir: \"./data/|cache_dir: \"${DATA_DIR}/data/|g" "${TARGET_CONFIG}"
    fi

    chown "${PACKAGE_USER}" "${TARGET_CONFIG}"
    chmod 664 "${TARGET_CONFIG}"

    echo "配置: ${TARGET_CONFIG}"
    echo "端口: ${PORT}"



    # 动态更新桌面快捷方式的 URL 端口
    UI_CONFIG="${TARGET_DIR}/ui/config"
    if [ -f "${UI_CONFIG}" ]; then
        sed -i "s|{{PORT}}|${PORT}|g" "${UI_CONFIG}"
    fi

    # 动态写入 INFO 让套件中心显示“打开”按钮
    INFO_FILE="/var/packages/${PACKAGE_NAME}/INFO"
    if [ -f "${INFO_FILE}" ]; then
        sed -i -e '/^adminport=/d' -e '/^adminurl=/d' "${INFO_FILE}"
        echo "adminurl=\"http://%s:${PORT}/admin\"" >> "${INFO_FILE}"
    fi


# 4. 记录数据路径（供 start-stop-status 使用）
echo "${DATA_DIR}" > "${TARGET_DIR}/var/data_path"

# 5. 确保包用户拥有数据目录的写权限
chown -R "${PACKAGE_USER}" "${DATA_DIR}"
chmod -R 775 "${DATA_DIR}"

# 6. 校验
echo "=== 校验 ==="
ls -la "${DATA_DIR}/"
ls -la "${DATA_DIR}/data/" 2>/dev/null || true
ls -la "${DATA_DIR}/config/" 2>/dev/null || true

echo "MediaPlayer 安装完成！"
exit 0
