#!/bin/sh

# Post-installation script for MediaPlayer (DSM 7)

PACKAGE_NAME="MediaPlayer"
TARGET_DIR="/var/packages/${PACKAGE_NAME}/target"

# 优先使用本次安装向导提交的自定义存储路径，其次使用已有保存的 data_path
get_data_dir() {
    # 1. 优先读取安装向导提交的自定义存储路径
    SYNOGETKEY="/usr/syno/bin/synogetkeyvalue"
    CUSTOM_DIR=""

    if [ -n "${SYNOPKG_TEMP_LOGFILE}" ] && [ -f "${SYNOPKG_TEMP_LOGFILE}" ] && [ -x "${SYNOGETKEY}" ]; then
        CUSTOM_DIR=$("${SYNOGETKEY}" "${SYNOPKG_TEMP_LOGFILE}" "pkgwizard_data_dir" 2>/dev/null)
        [ -z "${CUSTOM_DIR}" ] && CUSTOM_DIR=$("${SYNOGETKEY}" "${SYNOPKG_TEMP_LOGFILE}" "wizard_data_dir" 2>/dev/null)
    fi

    [ -z "${CUSTOM_DIR}" ] && CUSTOM_DIR="${pkgwizard_data_dir}"
    [ -z "${CUSTOM_DIR}" ] && CUSTOM_DIR="${wizard_data_dir}"

    if [ -n "${CUSTOM_DIR}" ]; then
        if mkdir -p "${CUSTOM_DIR}" 2>/dev/null; then
            if touch "${CUSTOM_DIR}/.test_write" 2>/dev/null; then
                rm -f "${CUSTOM_DIR}/.test_write" 2>/dev/null || true
                echo "${CUSTOM_DIR}"
                return 0
            fi
        fi
    fi

    # 2. 次优先：若向导未指定，读取上次保留的 data_path
    for data_file in "${SYNOPKG_PKGVAR}/data_path" "${TARGET_DIR}/var/data_path"; do
        if [ -f "${data_file}" ]; then
            SAVED_DIR=$(cat "${data_file}" | tr -d '\r\n')
            if [ -n "${SAVED_DIR}" ] && [ -d "${SAVED_DIR}" ]; then
                echo "${SAVED_DIR}"
                return 0
            fi
        fi
    done

    if [ -n "${SYNOPKG_SHARE_PATH}" ] && [ -d "${SYNOPKG_SHARE_PATH}" ]; then
        echo "${SYNOPKG_SHARE_PATH}"
        return 0
    fi

    REAL_TARGET=$(readlink -f "${TARGET_DIR}" 2>/dev/null || realpath "${TARGET_DIR}" 2>/dev/null || echo "${SYNOPKG_PKGDEST:-}")
    VOL_DIR=$(echo "${REAL_TARGET}" | awk -F'/' '{if ($2 ~ /^volume/) print "/"$2}')
    [ -z "${VOL_DIR}" ] && VOL_DIR="/volume1"

    for candidate in "/var/services/web_packages/${PACKAGE_NAME}" "${VOL_DIR}/web_packages/${PACKAGE_NAME}"; do
        if [ -d "${candidate}" ] || mkdir -p "${candidate}" 2>/dev/null; then
            if touch "${candidate}/.test_write" 2>/dev/null; then
                rm -f "${candidate}/.test_write" 2>/dev/null || true
                echo "${candidate}"
                return 0
            fi
        fi
    done

    echo "${SYNOPKG_PKGVAR:-/var/packages/${PACKAGE_NAME}/var}"
}

DATA_DIR=$(get_data_dir)

echo "开始安装 MediaPlayer..."
echo "安装目录: ${TARGET_DIR}"
echo "数据目录: ${DATA_DIR}"

# 1. 设置执行权限
chmod +x "${TARGET_DIR}/bin/mediaplayer" 2>/dev/null || true
chmod +x "${TARGET_DIR}/scripts/"* 2>/dev/null || true

# 2. 创建数据目录结构（共享文件夹内部路径）
mkdir -p "${DATA_DIR}/data/cache"
mkdir -p "${SYNOPKG_PKGVAR}" 2>/dev/null || true

# 3. 提取向导输入的自定义端口与管理员密码，生成或更新配置文件
TARGET_CONFIG="${DATA_DIR}/config.yaml"
TEMPLATE_FILE="${TARGET_DIR}/etc/config.yaml.template"
[ ! -f "${TEMPLATE_FILE}" ] && TEMPLATE_FILE="${TARGET_DIR}/etc/config.yaml"

SYNOGETKEY="/usr/syno/bin/synogetkeyvalue"

WIZARD_PORT=""
if [ -n "${SYNOPKG_TEMP_LOGFILE}" ] && [ -f "${SYNOPKG_TEMP_LOGFILE}" ] && [ -x "${SYNOGETKEY}" ]; then
    WIZARD_PORT=$("${SYNOGETKEY}" "${SYNOPKG_TEMP_LOGFILE}" "pkgwizard_server_port" 2>/dev/null)
    [ -z "${WIZARD_PORT}" ] && WIZARD_PORT=$("${SYNOGETKEY}" "${SYNOPKG_TEMP_LOGFILE}" "server_port" 2>/dev/null)
fi
[ -z "${WIZARD_PORT}" ] && WIZARD_PORT="${pkgwizard_server_port}"
[ -z "${WIZARD_PORT}" ] && WIZARD_PORT="${server_port}"

WIZARD_PWD=""
if [ -n "${SYNOPKG_TEMP_LOGFILE}" ] && [ -f "${SYNOPKG_TEMP_LOGFILE}" ] && [ -x "${SYNOGETKEY}" ]; then
    WIZARD_PWD=$("${SYNOGETKEY}" "${SYNOPKG_TEMP_LOGFILE}" "pkgwizard_admin_password" 2>/dev/null)
    [ -z "${WIZARD_PWD}" ] && WIZARD_PWD=$("${SYNOGETKEY}" "${SYNOPKG_TEMP_LOGFILE}" "admin_password" 2>/dev/null)
fi
[ -z "${WIZARD_PWD}" ] && WIZARD_PWD="${pkgwizard_admin_password}"
[ -z "${WIZARD_PWD}" ] && WIZARD_PWD="${admin_password}"

if [ ! -f "${TARGET_CONFIG}" ]; then
    echo "全新安装，生成配置文件..."
    if [ -f "${TEMPLATE_FILE}" ]; then
        cp "${TEMPLATE_FILE}" "${TARGET_CONFIG}"
    fi
fi

if [ -f "${TARGET_CONFIG}" ]; then
    if [ -n "${WIZARD_PORT}" ]; then
        PORT="${WIZARD_PORT}"
        sed -i -E "s/^[[:space:]]*port:.*$/  port: ${PORT}/" "${TARGET_CONFIG}"
        echo "配置端口已设定为向导值: ${PORT}"
    else
        PORT=$(grep '^[[:space:]]*port:' "${TARGET_CONFIG}" | awk '{print $2}' | tr -d '\r')
        [ -z "${PORT}" ] && PORT="9527"
    fi

    if [ -n "${WIZARD_PWD}" ]; then
        sed -i -E "s/^[[:space:]]*admin_password:.*$/  admin_password: \"${WIZARD_PWD}\"/" "${TARGET_CONFIG}"
        echo "管理员密码已设定为向导设定值"
    fi

    SECRET_KEY=$(head -c 32 /dev/urandom | tr -dc 'a-zA-Z0-9' | head -c 32 2>/dev/null)
    [ -z "${SECRET_KEY}" ] && SECRET_KEY="mediaplayer-fallback-$(date +%s)"

    sed -i "s|\./data/|${DATA_DIR}/data/|g" "${TARGET_CONFIG}"
    sed -i "s|\"mediaplayer-change-this-secret-key\"|\"${SECRET_KEY}\"|g" "${TARGET_CONFIG}"
fi

# 动态更新桌面快捷方式的 URL 端口和重定向页面的端口
UI_CONFIG="${TARGET_DIR}/ui/config"
if [ -f "${UI_CONFIG}" ]; then
    sed -i "s|{{PORT}}|${PORT}|g" "${UI_CONFIG}" 2>/dev/null || true
fi

UI_INDEX="${TARGET_DIR}/ui/index.html"
if [ -f "${UI_INDEX}" ]; then
    sed -i "s|{{PORT}}|${PORT}|g" "${UI_INDEX}" 2>/dev/null || true
fi

# 4. 记录数据路径（供 start-stop-status 使用）
echo "${DATA_DIR}" > "${SYNOPKG_PKGVAR}/data_path"

# 5. 校验
echo "=== 校验 ==="
ls -la "${DATA_DIR}/" 2>/dev/null || true
ls -la "${DATA_DIR}/data/" 2>/dev/null || true

echo "MediaPlayer 安装完成！"
exit 0
