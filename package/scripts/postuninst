#!/bin/sh

# Post-uninstallation script for MediaPlayer

PACKAGE_NAME="MediaPlayer"
TARGET_DIR="/var/packages/${PACKAGE_NAME}/target"
DATA_DIR_FILE="${TARGET_DIR}/var/data_path"

echo "Post-uninstall: ${PACKAGE_NAME}"

# Read data path
if [ -f "${DATA_DIR_FILE}" ]; then
    DATA_DIR=$(cat "${DATA_DIR_FILE}" | tr -d '
')
else
    DATA_DIR="/volume1/MediaPlayerData"
fi

# Data is preserved in the user-specified directory
echo "数据保留在: ${DATA_DIR}"
echo "如需彻底删除数据，请手动执行: rm -rf ${DATA_DIR}"

exit 0