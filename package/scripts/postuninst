#!/bin/sh

# Post-uninstallation script for MediaPlayer

PACKAGE_NAME="MediaPlayer"
TARGET_DIR="/var/packages/${PACKAGE_NAME}/target"

echo "Post-uninstall: Cleaning up ${PACKAGE_NAME}..."

# Remove symlink if exists
rm -f /usr/local/bin/mediaplayer 2>/dev/null

echo "Post-uninstall complete."
echo "Data files preserved at: ${TARGET_DIR}/var/"
echo "To fully remove: rm -rf /var/packages/${PACKAGE_NAME}/"

exit 0
