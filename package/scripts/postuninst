#!/bin/sh

# Post-uninstallation script for MediaPlayer (DSM 7)
# 卸载后执行，用于清理持久化数据（如果用户选择了彻底删除）

PACKAGE_NAME="MediaPlayer"
# 优先使用 File Station 中完全可见的 web_packages / web 共享目录
get_data_dir() {
    VOL_DIR=$(echo "${SYNOPKG_PKGDEST:-}" | awk -F'/' '{if ($2 ~ /^volume/) print "/"$2}')
    [ -z "${VOL_DIR}" ] && VOL_DIR="/volume1"

    if [ -d "${VOL_DIR}/web_packages/${PACKAGE_NAME}" ]; then
        echo "${VOL_DIR}/web_packages/${PACKAGE_NAME}"
        return 0
    elif [ -d "/var/services/web_packages/${PACKAGE_NAME}" ]; then
        echo "/var/services/web_packages/${PACKAGE_NAME}"
        return 0
    fi

    if [ -n "${SYNOPKG_SHARE_PATH}" ] && [ -d "${SYNOPKG_SHARE_PATH}" ]; then
        echo "${SYNOPKG_SHARE_PATH}"
        return 0
    fi

    SYNO_SHARE_GET=$(synoshare --get "${PACKAGE_NAME}" 2>/dev/null | grep -i "Path" | awk -F'[' '{print $2}' | tr -d ']')
    if [ -n "${SYNO_SHARE_GET}" ] && [ -d "${SYNO_SHARE_GET}" ]; then
        echo "${SYNO_SHARE_GET}"
        return 0
    fi

    echo "${SYNOPKG_PKGVAR:-/var/packages/${PACKAGE_NAME}/var}"
}

DATA_DIR=$(get_data_dir)

echo "========== MediaPlayer Post-Uninstall =========="

# 检查向导传过来的 uninstall_mode / delete_data / keep_data 环境变量
if [ "${uninstall_mode}" = "delete_data" ] || [ "${delete_data}" = "true" ] || [ "${delete_data}" = "delete_data" ] || [ "${keep_data}" = "false" ]; then
    echo "用户选择了彻底删除数据，开始清理所有持久化数据与系统残留..."

    # 1. 尝试使用 synoshare 注销共享文件夹注册表
    if command -v synoshare >/dev/null 2>&1; then
        synoshare --del "${PACKAGE_NAME}" 2>/dev/null || true
    elif [ -x "/usr/syno/bin/synoshare" ]; then
        /usr/syno/bin/synoshare --del "${PACKAGE_NAME}" 2>/dev/null || true
    fi

    # 2. 彻底删除共享目录中的套件文件夹 (web_packages / 独立共享文件夹)
    rm -rf /volume*/web_packages/${PACKAGE_NAME} 2>/dev/null || true
    rm -rf /var/services/web_packages/${PACKAGE_NAME} 2>/dev/null || true
    rm -rf /volume*/${PACKAGE_NAME} 2>/dev/null || true

    if [ -n "${DATA_DIR}" ] && [ -d "${DATA_DIR}" ]; then
        rm -rf "${DATA_DIR}" 2>/dev/null || true
    fi

    # 3. 清理系统卷下的 @appdata, @apphome, @appshare, @appconf, @apptemp, @eaDir 残留
    rm -rf /volume*/@appdata/${PACKAGE_NAME} 2>/dev/null || true
    rm -rf /volume*/@apphome/${PACKAGE_NAME} 2>/dev/null || true
    rm -rf /volume*/@appshare/${PACKAGE_NAME} 2>/dev/null || true
    rm -rf /volume*/@appconf/${PACKAGE_NAME} 2>/dev/null || true
    rm -rf /volume*/@apptemp/${PACKAGE_NAME} 2>/dev/null || true
    rm -rf /volume*/@eaDir/${PACKAGE_NAME} 2>/dev/null || true
    rm -rf /var/packages/${PACKAGE_NAME} 2>/dev/null || true

    echo "所有套件相关残留目录已彻底清空。"
else
    echo "用户选择了保留数据，或未执行卸载向导。"
    echo "数据安全保存在共享文件夹: ${DATA_DIR}"
fi

exit 0
